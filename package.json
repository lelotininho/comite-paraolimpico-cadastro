{
  "name": "comite-paraolimpico-cadastro",
  "version": "0.1.0",
  "author": "Wesley",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "npx cypress run",
    "setup": "bash setup.sh",
    "test:positive": "npx cypress run --spec \"cypress/e2e/positive/**/*.cy.js\"",
    "test:negative": "npx cypress run --spec \"cypress/e2e/negative/**/*.cy.js\"",
    "test:flow": "npx cypress run --spec \"cypress/e2e/flow/**/*.cy.js\"",
    "test:api": "npx cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:all": "npx cypress run",
    "test:open": "npx cypress open",
    "perf": "k6 run k6/registration.js",
    "collect:evidence": "node evidence-collector/index.js",
    "generate:metrics": "node metrics/summary-generator.js"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.1.0",
    "cypress": "^13.17.0"
  }
}
